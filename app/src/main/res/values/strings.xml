    <string name="changelog_title">Changelog</string>
    <string name="changelog_version_0_1_0">v0.1.0 - Basic Build</string>
    <string name="changelog_content_0_1_0">- Basic framework created with Kotlin guided by Gemini AI in Firebase Studio.</string>
    <string name="changelog_version_1_0_0">v0.1.1 - Major Update</string>
    <string name="changelog_content_1_0_0">- Completed basic translation functions.</string>
    <string name="changelog_version_1_0_1">v0.1.2 - Layout Optimization</string>
    <string name="changelog_content_1_0_1">- Optimized settings page layout.</string>
    <string name="changelog_version_1_0_2">v0.1.3 - Import Fix</string>
    <string name="changelog_content_1_0_2">- Fixed zip import not working when files are in subdirectories.\n- Fixed language selection not being reset when changing language groups.\n- Fixed info bar displaying incorrectly when no files are loaded.</string>
    <string name="changelog_version_1_1_0">v0.1.4 - Initial Release</string>
    <string name="changelog_content_1_1_0">- Added collapsible search bar.\n- Added functionality to stage changes.\n- Fixed several bugs.</string>
    <string name="changelog_version_0_1_5">v0.1.5</string>
    <string name="changelog_content_0_1_5">- Added interactive translator.</string>
    <string name="changelog_version_0_1_6">v0.1.6</string>
    <string name="changelog_content_0_1_6">- Fixed compilation errors.\n- Replaced splash screen icon with app icon.\n- Updated version code to 10 and version name to 0.1.6.</string>
    <string name="changelog_version_0_1_7">v0.1.7</string>
    <string name="changelog_content_0_1_7">- Added keyword highlighting feature.\n- Optimized editing experience.</string>

